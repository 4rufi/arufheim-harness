{
  "name": "arufheim-harness",
  "version": "0.0.16",
  "type": "module",
  "packageManager": "pnpm@10.33.4",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "harness-mcp": "node dist/index.js",
    "smoke": "node scripts/smoke-stdio.mjs",
    "test": "node scripts/smoke-stdio.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "verify": "./scripts/pnpmw.sh typecheck && ./scripts/pnpmw.sh build && ./scripts/pnpmw.sh smoke"
  },
  "bin": {
    "arufheim-harness": "./dist/index.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.2",
    "fast-glob": "^3.3.3",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.0.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ]
}
